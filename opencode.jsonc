{
  "$schema": "https://opencode.ai/config.json",
  "permission": {},
  "formatter": {
    "clang-format": {
      "extensions": [
        ".m",
        ".mm"
      ]
    }
  },
  "lsp": {
    "clangd": {
      "command": [
        "clangd",
        "--query-driver=/Applications/Xcode.app/**/clang,/usr/bin/clang"
      ],
      "extensions": [
        ".c",
        ".cc",
        ".cpp",
        ".cxx",
        ".h",
        ".hh",
        ".hpp",
        ".hxx",
        ".m",
        ".mm"
      ]
    },
    "sourcekit-lsp": {
      "disabled": true
    }
  },
  "mcp": {}
}
