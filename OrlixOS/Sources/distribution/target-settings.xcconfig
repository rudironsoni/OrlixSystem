ORLIX_OS_KSELFTEST_INITRAMFS_BUNDLE_NAME = OrlixTestInitramfs
ORLIX_OS_KSELFTEST_INITRAMFS_BUNDLE_IDENTIFIER = org.orlix.OrlixTestInitramfs
ORLIX_OS_KSELFTEST_INITRAMFS_SOURCE_ROOT = Build/OrlixMLibC/test-initramfs
ORLIX_OS_MLIBC_ROOT_IMAGE_IDENTIFIER = orlix.test.mlibc.rootfs
ORLIX_OS_MLIBC_ROOT_IMAGE_ROLE = mlibc
ORLIX_OS_MLIBC_INITRAMFS_BUNDLE_NAME = OrlixMLibCTestInitramfs
ORLIX_OS_MLIBC_INITRAMFS_BUNDLE_IDENTIFIER = org.orlix.OrlixMLibCTestInitramfs
ORLIX_OS_MLIBC_INITRAMFS_SOURCE_ROOT = Build/OrlixMLibC/test-initramfs
ORLIX_OS_COREUTILS_ROOT_IMAGE_IDENTIFIER = orlix.test.coreutils.rootfs
ORLIX_OS_COREUTILS_ROOT_IMAGE_ROLE = coreutils
ORLIX_OS_COREUTILS_INITRAMFS_BUNDLE_NAME = CoreutilsTestInitramfs
ORLIX_OS_COREUTILS_INITRAMFS_BUNDLE_IDENTIFIER = org.orlix.CoreutilsTestInitramfs
ORLIX_OS_COREUTILS_INITRAMFS_SOURCE_ROOT = Build/OrlixOS/test-initramfs
ORLIX_OS_TEST_INITRAMFS_RESOURCE = rootfs/initramfs.cpio.gz
ORLIX_OS_TEST_INITRAMFS_BUNDLE_EXTENSION = bundle
ORLIX_OS_PAYLOAD_BUNDLE_NAME = OrlixOSPayload
ORLIX_OS_PAYLOAD_BUNDLE_EXTENSION = bundle
ORLIX_OS_PAYLOAD_SOURCE_BUNDLE_NAME = OrlixKernelPayload
ORLIX_OS_PAYLOAD_SOURCE_BUNDLE_IDENTIFIER = org.orlix.OrlixKernelPayload
ORLIX_OS_PAYLOAD_SELECTED_PROFILE_INFO_KEY = OrlixSelectedProfile
ORLIX_OS_PAYLOAD_KERNEL_COMMAND_LINE_INFO_KEY = OrlixKernelCommandLine
ORLIX_OS_PAYLOAD_ROOT_INITRAMFS_INFO_KEY = OrlixRootInitramfs
ORLIX_OS_PAYLOAD_BASE_ROOT_IMAGE_INFO_KEY = OrlixBaseRootImage
ORLIX_OS_PAYLOAD_STATE_ROOT_IMAGE_INFO_KEY = OrlixStateRootImage
ORLIX_OS_PAYLOAD_BASE_ROOT_DEVICE_INFO_KEY = OrlixBaseRootDevice
ORLIX_OS_PAYLOAD_STATE_ROOT_DEVICE_INFO_KEY = OrlixStateRootDevice
ORLIX_OS_PAYLOAD_BASE_ROOT_HOST_BLOCK_DEVICE_INFO_KEY = OrlixBaseRootHostBlockDevice
ORLIX_OS_PAYLOAD_STATE_ROOT_HOST_BLOCK_DEVICE_INFO_KEY = OrlixStateRootHostBlockDevice
ORLIX_OS_PAYLOAD_STATE_ROOT_MINIMUM_BYTES_INFO_KEY = OrlixStateRootMinimumBytes
ORLIX_OS_LINUX_PAGE_SIZE = 4096
ORLIX_OS_ROOT_INITRAMFS_RESOURCE = rootfs/initramfs.cpio.gz
ORLIX_OS_BASE_ROOT_IMAGE_RESOURCE = rootfs/base.ext4
ORLIX_OS_STATE_ROOT_IMAGE_RESOURCE = rootfs/state.ext4
ORLIX_OS_ROOT_MODES = initramfs-only direct overlay
ORLIX_OS_RELEASE_ROOT_MODE = direct
ORLIX_OS_DEVELOPMENT_ROOT_MODE = overlay
ORLIX_OS_RELEASE_KERNEL_COMMAND_LINE = console=ttyS0 console=hvc0 root=/dev/vda rootfstype=ext4 ro orlix.profile=release
ORLIX_OS_DEVELOPMENT_KERNEL_COMMAND_LINE = console=ttyS0 console=hvc0 rdinit=/init orlix.root=overlay debug ignore_loglevel orlix.profile=development
ORLIX_OS_RELEASE_TEST_INITRAMFS_KERNEL_COMMAND_LINE = console=ttyS0 console=hvc0 rdinit=/init orlix.root=initramfs-only orlix.profile=release
ORLIX_OS_DEVELOPMENT_TEST_INITRAMFS_KERNEL_COMMAND_LINE = console=ttyS0 console=hvc0 rdinit=/init orlix.root=initramfs-only debug ignore_loglevel orlix.profile=development
ORLIX_OS_TEST_INITRAMFS_KERNEL_COMMAND_LINE = $(ORLIX_OS_RELEASE_TEST_INITRAMFS_KERNEL_COMMAND_LINE)
ORLIX_OS_BASE_ROOT_DEVICE = /dev/vda
ORLIX_OS_STATE_ROOT_DEVICE = /dev/vdb
ORLIX_OS_BASE_ROOT_HOST_BLOCK_DEVICE = 0
ORLIX_OS_STATE_ROOT_HOST_BLOCK_DEVICE = 1
ORLIX_OS_BASE_ROOT_IMAGE_SIZE = 64m
ORLIX_OS_STATE_ROOT_IMAGE_SIZE = 32m
ORLIX_OS_STATE_ROOT_MINIMUM_BYTES = 16777216
