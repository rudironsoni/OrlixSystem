+	bool active_codeset_is_utf8() {
+		auto codeset = mlibc::getActiveLocale()->ctype.get(CODESET).asString();
+		return codeset.size() == 5
+			&& (codeset[0] == 'U' || codeset[0] == 'u')
+			&& (codeset[1] == 'T' || codeset[1] == 't')
+			&& (codeset[2] == 'F' || codeset[2] == 'f')
+			&& codeset[3] == '-'
+			&& codeset[4] == '8';
+	}
+
+	size_t decode_ascii(wchar_t *wcp, const char *mbs, size_t mb_limit,
+			mbstate_t *stp) {
+		if(!mb_limit)
+			return static_cast<size_t>(-2);
+
+		auto uc = static_cast<unsigned char>(mbs[0]);
+		if(uc > 0x7F) {
+			errno = EILSEQ;
+			return static_cast<size_t>(-1);
+		}
+
+		if(wcp)
+			*wcp = uc;
+		if(!uc) {
+			*stp = __MLIBC_MBSTATE_INITIALIZER;
+			return 0;
+		}
+		return 1;
+	}
