+template<typename Char>
+static bool ascii_equal_ignoring_case(Char a, Char b) {
+	if (a >= 'A' && a <= 'Z')
+		a = a - 'A' + 'a';
+	if (b >= 'A' && b <= 'Z')
+		b = b - 'A' + 'a';
+	return a == b;
+}
+
+template<typename Char>
+static bool starts_with_ignoring_case(const Char *str, const Char *prefix, size_t length) {
+	for (size_t i = 0; i < length; i++) {
+		if (!str[i] || !ascii_equal_ignoring_case(str[i], prefix[i]))
+			return false;
+	}
+	return true;
+}
+
+template<typename T>
+static T infinity_result(bool negative) {
+	if constexpr (std::is_same_v<T, float>)
+		return negative ? -__builtin_inff() : __builtin_inff();
+	else if constexpr (std::is_same_v<T, double>)
+		return negative ? -__builtin_inf() : __builtin_inf();
+	else
+		return negative ? -__builtin_infl() : __builtin_infl();
+}
