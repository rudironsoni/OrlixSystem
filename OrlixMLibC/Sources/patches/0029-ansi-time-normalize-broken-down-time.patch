+	auto append_char = [](Char *&out, size_t &space, Char ch) {
+		if(!space)
+			return false;
+		*out++ = ch;
+		space--;
+		return true;
+	};
+
+	auto append_literal = [&](Char *&out, size_t &space, const Char *begin, const Char *end, bool uppercase = false) {
+		for(auto q = begin; q != end; q++) {
+			Char ch = *q;
+			if(uppercase && ch >= static_cast<Char>('a') && ch <= static_cast<Char>('z'))
+				ch = ch - static_cast<Char>('a') + static_cast<Char>('A');
+			if(!append_char(out, space, ch))
+				return false;
+		}
+		return true;
+	};
+
+	auto append_number = [&](Char *&out, size_t &space, long long value, int default_width,
+			Char default_pad, bool force_plus, bool no_padding, int requested_width = -1,
+			Char requested_pad = 0) {
+		Char digits[64];
+		size_t digit_count = 0;
+		bool negative = value < 0;
+		unsigned long long magnitude = negative
+			? 0 - static_cast<unsigned long long>(value)
+			: static_cast<unsigned long long>(value);
+
+		do {
+			digits[digit_count++] = static_cast<Char>('0' + (magnitude % 10));
+			magnitude /= 10;
+		} while(magnitude);
+
+		Char sign = 0;
+		if(negative)
+			sign = static_cast<Char>('-');
+		else if(force_plus)
+			sign = static_cast<Char>('+');
+
+		int width = requested_width >= 0 ? requested_width : default_width;
+		Char pad = requested_pad ? requested_pad : default_pad;
+		size_t length = digit_count + (sign ? 1 : 0);
+		size_t padding = !no_padding && width > static_cast<int>(length) ? width - length : 0;
+
+		if(pad == static_cast<Char>('0') && sign) {
+			if(!append_char(out, space, sign))
+				return false;
+			sign = 0;
+		}
+		while(padding--) {
+			if(!append_char(out, space, pad))
+				return false;
+		}
+		if(sign && !append_char(out, space, sign))
+			return false;
+		while(digit_count--) {
+			if(!append_char(out, space, digits[digit_count]))
+				return false;
+		}
+		return true;
+	};
