 namespace {
 
+constexpr time_t seconds_per_minute = 60;
+constexpr time_t seconds_per_hour = 60 * seconds_per_minute;
+constexpr time_t seconds_per_day = 24 * seconds_per_hour;
+
+time_t floor_div(time_t dividend, time_t divisor) {
+	time_t quotient = dividend / divisor;
+	time_t remainder = dividend % divisor;
+	if(remainder < 0)
+		quotient--;
+	return quotient;
+}
+
+time_t floor_mod(time_t dividend, time_t divisor) {
+	time_t remainder = dividend % divisor;
+	if(remainder < 0)
+		remainder += divisor;
+	return remainder;
+}
