 time_t mktime(struct tm *tm) {
-	return timegm(tm);
+	tzset();
+
+	struct tm wanted = *tm;
+	time_t candidate = timegm(&wanted);
+	struct tm normalized;
+
+	for(int i = 0; i < 4; i++) {
+		if(!localtime_r(&candidate, &normalized))
+			return static_cast<time_t>(-1);
+
+		if(normalized.tm_sec == wanted.tm_sec
+				&& normalized.tm_min == wanted.tm_min
+				&& normalized.tm_hour == wanted.tm_hour
+				&& normalized.tm_mday == wanted.tm_mday
+				&& normalized.tm_mon == wanted.tm_mon
+				&& normalized.tm_year == wanted.tm_year) {
+			*tm = normalized;
+			return candidate;
+		}
+
+		struct tm wanted_utc = wanted;
+		struct tm normalized_utc = normalized;
+		time_t wanted_as_utc = timegm(&wanted_utc);
+		time_t normalized_as_utc = timegm(&normalized_utc);
+		candidate += wanted_as_utc - normalized_as_utc;
+	}
+
+	if(!localtime_r(&candidate, &normalized))
+		return static_cast<time_t>(-1);
+	*tm = normalized;
+	return candidate;
 }
 
