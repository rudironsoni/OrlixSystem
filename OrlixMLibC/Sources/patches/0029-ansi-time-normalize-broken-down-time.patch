+time_t time_from_rule(const Rule &rule, int year, time_t offset_before_transition) {
+	time_t year_start = days_from_civil_for_rule(year, 1, 1);
+	time_t local_seconds = (year_start + transition_day_from_rule(rule, year)) * seconds_per_day + rule.time;
+	return local_seconds - offset_before_transition;
