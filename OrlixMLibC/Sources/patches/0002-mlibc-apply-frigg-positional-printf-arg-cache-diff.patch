++		return *reinterpret_cast<T*>(&vsp->arg_list[pos].f);
++	else
++		return *reinterpret_cast<T*>(&vsp->arg_list[pos].i);
++}
++
++template<typename T>
++void cache_next_arg(va_struct *vsp, int pos) {
++	store_cached_arg<T>(vsp, pos, pop_direct_arg<T>(vsp));
++}
