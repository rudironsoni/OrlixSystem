diff --git a/tests/posix/renameat2.c b/tests/posix/renameat2.c
new file mode 100644
index 00000000..7e833d82
--- /dev/null
+++ b/tests/posix/renameat2.c
@@ -0,0 +1,60 @@
+#ifndef _GNU_SOURCE
+#define _GNU_SOURCE
+#endif
+
+#include <assert.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <linux/fs.h>
+#include <stdio.h>
+#include <string.h>
+#include <unistd.h>
+
+int main(void) {
+	const char *old_path = "/tmp/mlibc-renameat2-old";
+	const char *new_path = "/tmp/mlibc-renameat2-new";
+
+	unlink(old_path);
+	unlink(new_path);
+
+	FILE *file = fopen(old_path, "w");
+	assert(file);
+	assert(fputs("renameat2\n", file) >= 0);
+	assert(!fclose(file));
+
+	assert(!renameat2(AT_FDCWD, old_path, AT_FDCWD, new_path, 0));
+
+	file = fopen(new_path, "r");
+	assert(file);
+	char buffer[32];
+	assert(fgets(buffer, sizeof(buffer), file));
+	assert(!strcmp(buffer, "renameat2\n"));
+	assert(!fclose(file));
+
+	file = fopen(old_path, "w");
+	assert(file);
+	assert(fputs("noreplace\n", file) >= 0);
+	assert(!fclose(file));
+
+	errno = 0;
+	assert(renameat2(AT_FDCWD, old_path, AT_FDCWD, new_path, RENAME_NOREPLACE) == -1);
+	assert(errno == EEXIST);
+	assert(!unlink(new_path));
+
+	assert(!renameat2(AT_FDCWD, old_path, AT_FDCWD, new_path, RENAME_NOREPLACE));
+
+	file = fopen(new_path, "r");
+	assert(file);
+	assert(fgets(buffer, sizeof(buffer), file));
+	assert(!strcmp(buffer, "noreplace\n"));
+	assert(!fclose(file));
+
+	errno = 0;
+	assert(renameat2(AT_FDCWD, new_path, AT_FDCWD, old_path, 0xFFFFFFFFu) == -1);
+	assert(errno == EINVAL || errno == ENOSYS);
+
+	unlink(old_path);
+	unlink(new_path);
+
+	return 0;
+}
