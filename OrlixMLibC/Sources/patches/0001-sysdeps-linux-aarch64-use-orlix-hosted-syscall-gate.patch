index a07ed53e..18c95b28 100644
--- i/sysdeps/linux/generic/sysdeps.cpp
+++ w/sysdeps/linux/generic/sysdeps.cpp
@@ -44,6 +44,93 @@
 #include "generic-helpers/netlink.hpp"
 #endif
 
+#if defined(__aarch64__) && defined(ORLIX_HOSTED_EXEC)
+extern "C" uintptr_t __orlix_hosted_thread_pointer = 0;
+
+namespace {
+struct orlix_emutls_object {
+	size_t size;
+	size_t align;
+	uintptr_t object;
+	void *templ;
+};
+
+struct orlix_emutls_record {
+	uintptr_t thread_pointer;
+	orlix_emutls_object *object;
+	void *address;
+	orlix_emutls_record *next;
+};
+
+orlix_emutls_record *orlix_emutls_records;
+unsigned int orlix_emutls_lock_word;
+
+void orlix_emutls_lock()
+{
+	while (__atomic_exchange_n(&orlix_emutls_lock_word, 1, __ATOMIC_ACQUIRE))
+		;
+}
+
+void orlix_emutls_unlock()
+{
+	__atomic_store_n(&orlix_emutls_lock_word, 0, __ATOMIC_RELEASE);
+}
+
+uintptr_t orlix_align_up(uintptr_t value, uintptr_t align)
+{
+	return (value + align - 1) & ~(align - 1);
+}
+
+void *orlix_emutls_mmap(size_t size)
+{
+	auto ret = mlibc::do_syscall(SYS_mmap, nullptr, size,
+			PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+	if (mlibc::sc_error(ret))
+		__builtin_trap();
+	return mlibc::sc_ptr_result<void>(ret);
+}
+
+void *orlix_emutls_allocate_storage(orlix_emutls_object *object)
+{
+	size_t align = object->align > sizeof(void *) ? object->align : sizeof(void *);
+	size_t allocation_size = object->size + align - 1;
+	char *allocation = static_cast<char *>(orlix_emutls_mmap(allocation_size));
+	char *storage = reinterpret_cast<char *>(
+			orlix_align_up(reinterpret_cast<uintptr_t>(allocation), align));
+	char *templ = static_cast<char *>(object->templ);
+
+	for (size_t i = 0; i < object->size; i++)
+		storage[i] = templ ? templ[i] : 0;
+	return storage;
+}
+} // namespace
+
+extern "C" void *__emutls_get_address(orlix_emutls_object *object)
+{
+	uintptr_t thread_pointer = __orlix_hosted_thread_pointer;
+
+	orlix_emutls_lock();
+	for (orlix_emutls_record *record = orlix_emutls_records; record; record = record->next) {
+		if (record->thread_pointer == thread_pointer && record->object == object) {
+			void *address = record->address;
+			orlix_emutls_unlock();
+			return address;
+		}
+	}
+
+	void *address = orlix_emutls_allocate_storage(object);
+	orlix_emutls_record *record =
+			static_cast<orlix_emutls_record *>(orlix_emutls_mmap(sizeof(orlix_emutls_record)));
+	record->thread_pointer = thread_pointer;
+	record->object = object;
+	record->address = address;
+	record->next = orlix_emutls_records;
+	orlix_emutls_records = record;
+	orlix_emutls_unlock();
+	return address;
+}
